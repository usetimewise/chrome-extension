{
  "manifest_version": 3,
  "name": "Time Wise Tracker",
  "version": "0.2.0",
  "description": "A focus-first browser companion that tracks attention, surfaces drift patterns, and suggests calmer next steps.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "idle",
    "history"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "assets/media-monitor.js",
        "assets/focus-nudge.js"
      ],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/fontawesome/webfonts/fa-solid-900.woff2"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "action": {
    "default_title": "Time Wise: фокусировка выключена",
    "default_popup": "popup.html"
  }
}
